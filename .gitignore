# Dépendances
/vendor/
/node_modules/

# Configuration locale et secrets
.env
.env.*
!.env.example

# Logs applicatifs
/logs/*
!/logs/.gitkeep

# Fichiers uploadés par les utilisateurs (avatars) : jamais versionnés
/public/uploads/*
!/public/uploads/.gitkeep

# Fichiers spécifiques à l'IDE / au poste de développement
.vscode/
.idea/
.claude/
*.code-workspace

# Fichiers système
Thumbs.db
.DS_Store

# Caches et fichiers temporaires
*.log
*.tmp
